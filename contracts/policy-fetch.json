{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Policy Fetch Format",
  "type": "object",
  "required": ["policy_id", "version", "rules"],
  "properties": {
    "policy_id": {
      "type": "string",
      "description": "Unique identifier for this policy document"
    },
    "version": {
      "type": "integer",
      "description": "Monotonically increasing version number"
    },
    "rules": {
      "type": "object",
      "properties": {
        "allowed_tools": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of tools the AI is allowed to execute"
        },
        "approval_mode": {
          "type": "string",
          "enum": ["suggest_only", "ask_before_act", "auto_act"],
          "description": "Default approval mode for AI actions"
        }
      },
      "required": ["allowed_tools", "approval_mode"]
    }
  }
}
