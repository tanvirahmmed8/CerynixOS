{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Enrollment Token Format",
  "type": "object",
  "required": ["token", "organization_id", "endpoint"],
  "properties": {
    "token": {
      "type": "string",
      "description": "Cryptographic token for device enrollment"
    },
    "organization_id": {
      "type": "string",
      "description": "Tenant ID for the fleet control plane"
    },
    "endpoint": {
      "type": "string",
      "format": "uri",
      "description": "URL of the control plane enrollment service"
    }
  }
}
